# Copy to .env and fill in. Everything personal lives here, never in code.

OPENAI_API_KEY=sk-...

# Absolute path of the Obsidian vault on the host, mounted read-only at
# /vault inside the containers. On WSL, C:\ becomes /mnt/c/.
# Leave unset to use the committed demo_vault.
#VAULT_PATH=/mnt/c/Users/you/Documents/your-vault

# LLM provider. Default is the OpenAI API with gpt-5.4-mini. Any
# OpenAI-compatible server works instead, e.g. the optional local Ollama
# service (docker compose --profile ollama up -d):
#LLM_BASE_URL=http://ollama:11434/v1
#LLM_MODEL=llama3.2:3b

# Overrides (defaults shown)
#JUPYTER_TOKEN=dev
#POSTGRES_USER=user
#POSTGRES_PASSWORD=pswd
#GRAFANA_PASSWORD=admin
#EMBED_MODEL=all-MiniLM-L6-v2
#ES_INDEX=obsidian_notes

# Host ports. Change here if something on your machine already uses one;
#APP_PORT=8501
#JUPYTER_PORT=8888
#GRAFANA_PORT=3000
#ES_PORT=9200
#POSTGRES_PORT=5432
#OLLAMA_PORT=11434
